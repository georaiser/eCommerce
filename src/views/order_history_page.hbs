<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history me-2"></i>Order History</h2>
    <span class="badge bg-success fs-6"><i class="bi bi-wallet2 me-1"></i>Credit: ${{userCredit}}</span>
</div>

{{#if groupedOrders.length}}
    <div class="row g-4">
        {{#each groupedOrders}}
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span>
                        <span class="fw-bold">Order #{{this.order_id}}</span>
                        {{#if this.purchaser_name}}
                            <span class="badge bg-secondary ms-2"><i class="bi bi-person-fill"></i> {{this.purchaser_name}}</span>
                        {{/if}}
                    </span>
                    <span>Placed on: {{this.created_at}}</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Price at Purchase</th>
                                    <th>Quantity</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each this.items}}
                                <tr>
                                    <td>{{this.product_name}}</td>
                                    <td>${{this.price_at_purchase}}</td>
                                    <td>{{this.quantity}}</td>
                                    <td class="text-end fw-semibold">${{this.item_total}}</td>
                                </tr>
                                {{/each}}
                            </tbody>
                            <tfoot class="table-group-divider">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Order Total:</td>
                                    <td class="text-end fw-bold fs-5 text-success">${{this.total_paid}}</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
{{else}}
    <div class="alert alert-secondary text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
        <h4>No past orders found.</h4>
        <p class="text-muted">You haven't purchased anything yet. Head over to products to start shopping!</p>
        <a href="{{prefix}}/products" class="btn btn-primary mt-2">Browse Products</a>
    </div>
{{/if}}
