<div class="container py-5">

    <h1 class="text-center fw-bold mb-4">Welcome to CommerceManager</h1>

    <!-- Mode Selector -->
    <div class="row justify-content-center g-4 mb-5">

        <div class="col-md-4">
            <div class="card h-100 border-primary shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="mb-3 fs-1">🗄️</div>
                    <h4 class="fw-bold text-primary">SQL Mode</h4>
                    <p class="text-muted small">Raw PostgreSQL — <code>pg</code> pool<br><code>BEGIN / COMMIT / ROLLBACK</code></p>
                    <div class="d-grid gap-2 mt-3">
                        <a href="/sql/users"    class="btn btn-outline-primary">👤 Users</a>
                        <a href="/sql/products" class="btn btn-outline-primary">📦 Products</a>
                        <a href="/sql/cart"     class="btn btn-primary fw-bold">🛒 Cart &amp; Checkout</a>
                    </div>
                </div>
                <div class="card-footer text-center text-muted small">
                    <code>routes/SQL/</code> → <code>controllers/SQL/</code> → <code>models/SQL/</code>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-secondary shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="mb-3 fs-1">🔷</div>
                    <h4 class="fw-bold text-secondary">ORM Mode</h4>
                    <p class="text-muted small">Sequelize ORM — model classes<br><code>sequelize.transaction()</code></p>
                    <div class="d-grid gap-2 mt-3">
                        <a href="/orm/users"    class="btn btn-outline-secondary">👤 Users</a>
                        <a href="/orm/products" class="btn btn-outline-secondary">📦 Products</a>
                        <a href="/orm/cart"     class="btn btn-secondary fw-bold">🛒 Cart &amp; Checkout</a>
                    </div>
                </div>
                <div class="card-footer text-center text-muted small">
                    <code>routes/ORM/</code> → <code>controllers/ORM/</code> → <code>models/ORM/</code>
                </div>
            </div>
        </div>

    </div>

    <!-- Status Section -->
    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-check-circle-fill me-2"></i>What is working?
                </div>
                <div class="card-body">
                    <h6 class="text-success fw-bold mb-3">PostgreSQL Database Layer</h6>
                    <ul class="list-group list-group-flush border rounded shadow-sm">
                        <li class="list-group-item"><i class="bi bi-hdd-network text-secondary me-2"></i>Database & Table creation</li>
                        <li class="list-group-item"><i class="bi bi-table text-secondary me-2"></i>User, Product & Cart tables</li>
                        <li class="list-group-item"><i class="bi bi-code-square text-secondary me-2"></i>SQL CRUD Operations</li>
                        <li class="list-group-item"><i class="bi bi-layout-text-window text-secondary me-2"></i>Handlebars (hbs) UI views</li>
                        <li class="list-group-item"><i class="bi bi-cart-check text-secondary me-2"></i>Dynamic Shopping Cart</li>
                        <li class="list-group-item"><i class="bi bi-shield-check text-secondary me-2"></i>Inventory Stock validations</li>
                        <li class="list-group-item"><i class="bi bi-lock text-secondary me-2"></i>ACID Transaction isolation</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-5 mt-4 mt-md-0">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-hourglass-split me-2"></i>What remains to be implemented?
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush border rounded shadow-sm">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-diagram-3 text-secondary me-2"></i>Sequelize ORM layer</span>
                            <span class="badge bg-primary rounded-pill">Next</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-person-badge text-secondary me-2"></i>User Authentication</span>
                            <span class="badge bg-secondary rounded-pill">Pending</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-fingerprint text-secondary me-2"></i>Session Management</span>
                            <span class="badge bg-secondary rounded-pill">Pending</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-shield-lock text-secondary me-2"></i>Role Management (RBAC)</span>
                            <span class="badge bg-secondary rounded-pill">Pending</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>
