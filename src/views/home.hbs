<div class="container py-5">

    <h1 class="text-center fw-bold mb-4">Welcome to CommerceManager</h1>

    <!-- Mode Selector -->
    <div class="row justify-content-center g-4 mb-5">

        <div class="col-md-4">
            <div class="card h-100 border-primary shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="mb-3 fs-1">🗄️</div>
                    <h4 class="fw-bold text-primary">SQL Mode</h4>
                    <p class="text-muted small">Raw PostgreSQL — <code>pg</code> pool<br><code>BEGIN / COMMIT / ROLLBACK</code></p>
                    <div class="d-grid gap-2 mt-3">
                        {{#if isAdmin}}
                            <a href="/sql/users"    class="btn btn-outline-primary">👤 Users</a>
                            <a href="/sql/products" class="btn btn-outline-primary">📦 Products</a>
                            <a href="/sql/cart/history" class="btn btn-primary fw-bold">🌍 Global Orders</a>
                        {{else}}
                            <a href="/sql/cart"     class="btn btn-primary fw-bold">🛒 Shop / Cart</a>
                            <a href="/sql/cart/history" class="btn btn-outline-primary">📦 My Purchases</a>
                        {{/if}}
                    </div>
                </div>
                <div class="card-footer text-center text-muted small">
                    <code>routes/SQL/</code> → <code>controllers/SQL/</code> → <code>models/SQL/</code>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-secondary shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="mb-3 fs-1">🔷</div>
                    <h4 class="fw-bold text-secondary">ORM Mode</h4>
                    <p class="text-muted small">Sequelize ORM — model classes<br><code>sequelize.transaction()</code></p>
                    <div class="d-grid gap-2 mt-3">
                        {{#if isAdmin}}
                            <a href="/orm/users"    class="btn btn-outline-secondary">👤 Users</a>
                            <a href="/orm/products" class="btn btn-outline-secondary">📦 Products</a>
                            <a href="/orm/cart/history" class="btn btn-secondary fw-bold">🌍 Global Orders</a>
                        {{else}}
                            <a href="/orm/cart"     class="btn btn-secondary fw-bold">🛒 Shop / Cart</a>
                            <a href="/orm/cart/history" class="btn btn-outline-secondary">📦 My Purchases</a>
                        {{/if}}
                    </div>
                </div>
                <div class="card-footer text-center text-muted small">
                    <code>routes/ORM/</code> → <code>controllers/ORM/</code> → <code>models/ORM/</code>
                </div>
            </div>
        </div>

    </div>

    <!-- Status Section -->
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-check-circle-fill me-2"></i>What is working?
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush border rounded shadow-sm">
                        <li class="list-group-item"><i class="bi bi-hdd-network text-secondary me-2"></i>Database & Table creation</li>
                        <li class="list-group-item"><i class="bi bi-code-square text-secondary me-2"></i>Raw SQL CRUD Operations</li>
                        <li class="list-group-item"><i class="bi bi-diagram-3 text-success me-2"></i>Sequelize ORM Parity (100%)</li>
                        <li class="list-group-item"><i class="bi bi-layout-text-window text-secondary me-2"></i>Shared Handlebars UI views</li>
                        <li class="list-group-item"><i class="bi bi-cart-check text-secondary me-2"></i>Checkout & Inventory Transactions</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 mt-4 mt-md-0">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-shield-check me-2"></i>Security Mechanisms
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush border rounded shadow-sm">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-fingerprint text-primary me-2"></i>JWT Flow</span>
                            <span class="badge bg-success rounded-pill">Active</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-person-badge text-primary me-2"></i>Role Separation</span>
                            <span class="badge bg-success rounded-pill">Active</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-database-lock text-primary me-2"></i>DB Sync Syncs</span>
                            <span class="badge bg-success rounded-pill">Active</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Developer Profile Footer -->
    <div class="row justify-content-center mt-5 pt-3">
        <div class="col-12 text-center text-muted small pb-3">
            <hr class="w-25 mx-auto mb-4 opacity-50">
            <span class="fw-bold">Developed by Jorge Rodriguez</span>
            <br>
            <a href="https://www.linkedin.com/in/jrodrigueze/" target="_blank" class="btn btn-sm border text-warning mt-2 shadow-sm rounded-pill px-3 py-2 fw-medium">
                <i class="bi bi-linkedin fs-5 align-middle me-2" style="color: #2fc20a;"></i>Connect on LinkedIn
            </a>
        </div>
    </div>

</div>
