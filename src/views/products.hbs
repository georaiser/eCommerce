<h1>Products management</h1>

<div class="container">
  <div id="app" class="row mt-4">
    <div class="col-md-4">
      <div class="card">
        <div class="card-header">
          <h4>Add Product</h4>
        </div>
        <form id="product-form" class="card-body">
          <div class="form-group mb-3">
            <input
              type="text"
              id="name"
              placeholder="Product Name"
              class="form-control"
            />
          </div>
          <div class="form-group mb-3">
            <input
              type="text"
              id="category"
              placeholder="Product Category"
              class="form-control"
            />
          </div>
          <div class="form-group mb-3">
            <input
              type="number"
              id="price"
              placeholder="Product Price"
              class="form-control"
            />
          </div>

          <input
            type="submit"
            value="Add Product"
            class="btn btn-primary w-100 rounded-5"
          />
        </form>
      </div>
    </div>

    <div class="col-md-8">
      <table class="table table-ligth">
        <thead>
          <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Active</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each products}}
            <tr>
              <td>{{this.name}}</td>
              <td>{{this.category}}</td>
              <td>{{this.price}}</td>
              <td>{{this.stock}}</td>
              <td>{{this.isActive}}</td>
              <td>
                <button class="btn btn-secondary btn-sm">Edit</button>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="/products.js"></script>