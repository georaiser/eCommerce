<h1>Shopping Cart</h1>

<div class="container">
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Add Product</h4>
                </div>
                <table class="table table-ligth">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Quantity</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each products}}
                        <tr>
                            <td>{{this.name}}</td>
                            <td>{{this.category}}</td>
                            <td>{{this.price}}</td>
                            <td>{{this.stock}}</td>
                            <td>
                                <div class="form-group mb-0">
                                    <input type="number" class="form-control form-control-sm amount-input"
                                        style="width: 80px" min="0" max="{{this.stock}}" step="1" required />
                                </div>
                            </td>

                            <td>
                                <!-- Changed class to btn-add-cart so it doesn't conflict! -->
                                <button data-id="{{this.id}}"
                                    class="btn btn-secondary btn-sm btn-add-cart">AddProduct</button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4 class="d-flex justify-content-between align-items-center">
                        <span>Shopping Cart</span>
                        <div>
                            <span class="badge bg-primary text-light me-2">Credit: ${{userCredit}}</span>
                            <span class="badge bg-success rounded-pill">Total: ${{cartTotal}}</span>
                        </div>
                    </h4>
                </div>
                <table class="table table-ligth">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Total</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if cart}}
                        {{#each cart}}
                        <div class="cart-item">
                            <tr>
                                <td>{{this.name}}</td>
                                <td>{{this.quantity}}</td>
                                <td>{{this.price}}</td>
                                <td>{{this.total}}</td>
                                <td>
                                    <button data-id="{{this.product_id}}"
                                        class="btn btn-secondary btn-sm btn-update-cart">Edit</button>
                                    <button data-id="{{this.product_id}}"
                                        class="btn btn-secondary btn-sm btn-remove-cart">Del</button>
                                </td>
                            </tr>
                        </div>
                        {{/each}}
                        {{else}}
                        <p>Your cart is empty.</p>
                        {{/if}}

                    </tbody>
                </table>
                <div class="card-footer text-end mt-3">
                    <button class="btn btn-success fw-bold px-4 btn-checkout">
                        <i class="bi bi-credit-card me-2"></i> Checkout / Buy
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<script type="module" src="/cart.js"></script>